[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform float WindStrength = 1;
uniform sampler2D AlbedoTexture;
uniform vec4 ColorParameter : source_color = vec4(0.051200, 0.640000, 0.051200, 1.000000);
uniform float UVSpeed = 0.10000000149012;
uniform sampler2D tex_frg_10;
uniform float UVAmplitude = 0.00999999977648;
uniform sampler2D Noise;
uniform sampler2D Mask : repeat_disable;


// WindDisplacement

	global uniform sampler2D wind_noise_texture;
	global uniform vec3 wind_dir;
	global uniform float wind_strength;
	
	vec3 get_wind_displacement(vec3 global_position, float strength){
		float time_factor = 0.05;
		float position_factor = 0.01;
		vec3 wind = normalize((texture(wind_noise_texture, position_factor * global_position.xz + (time_factor * TIME) * wind_dir.xz).rgb - vec3(.5)) * vec3(1, 0.2, 1));
		float d = abs(dot(wind, wind_dir));
		return (strength * d * d * wind_strength) * wind;
	}
	
// NoiseColorTransformer

	
	#include \"res://addons/code_jar/shader_nodes/shaders/hsv2rgb.gdshaderinc\"
	
	vec3 noise_color_transformer(vec3 color, vec3 noise) {
		vec3 hsv_col = rgb2hsv(color);
		hsv_col = vec3(hsv_col.x, hsv_col.y * (noise.y * 0.2 + 0.8), hsv_col.z * (noise.z * 0.75 + 0.25));
		return hsv2rgb(hsv_col);
	}
		
	vec3 noise_normal_transformer(vec3 normal, vec3 noise, float normal_noise) {
		vec3 noise_vec = noise * 2.0 + vec3(-1.0);
		return normalize(normal + noise_vec * normal_noise);
	}
	

void vertex() {
// Input:20
	mat4 n_out20p0 = MODEL_MATRIX;


// TransformFunc:21
	mat4 n_out21p0 = inverse(n_out20p0);


// Input:22
	mat4 n_out22p0 = MODEL_MATRIX;


// Input:2
	vec3 n_out2p0 = VERTEX;


// TransformVectorMult:24
	vec3 n_out24p0 = (n_out22p0 * vec4(n_out2p0, 1.0)).xyz;


// Input:31
	vec3 n_out31p0 = NODE_POSITION_WORLD;


// Input:17
	vec4 n_out17p0 = COLOR;
	float n_out17p1 = n_out17p0.r;


// FloatOp:16
	float n_in16p1 = 2.00000;
	float n_out16p0 = pow(n_out17p1, n_in16p1);


// FloatParameter:33
	float n_out33p0 = WindStrength;


// FloatOp:34
	float n_out34p0 = n_out16p0 * n_out33p0;


	vec3 n_out30p0;
// WindDisplacement:30
	{
		n_out30p0
			 = get_wind_displacement(n_out31p0,n_out34p0);
			
	}


// VectorOp:32
	vec3 n_out32p0 = n_out24p0 + n_out30p0;


// TransformVectorMult:19
	vec3 n_out19p0 = (n_out21p0 * vec4(n_out32p0, 1.0)).xyz;


// Output:0
	VERTEX = n_out19p0;


}

void fragment() {
// Input:9
	vec2 n_out9p0 = UV;


	vec4 n_out21p0;
// Texture2D:21
	n_out21p0 = texture(AlbedoTexture, n_out9p0);


// ColorParameter:6
	vec4 n_out6p0 = ColorParameter;


// VectorOp:22
	vec3 n_out22p0 = vec3(n_out21p0.xyz) * vec3(n_out6p0.xyz);


// Input:11
	float n_out11p0 = TIME;


// FloatParameter:16
	float n_out16p0 = UVSpeed;


// FloatConstant:23
	float n_out23p0 = 0.400000;


// VectorOp:24
	vec3 n_out24p0 = vec3(n_out23p0) * vec3(n_out9p0, 0.0);


// MultiplyAdd:15
	vec2 n_out15p0 = fma(vec2(n_out11p0), vec2(n_out16p0), vec2(n_out24p0.xy));


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out15p0);


	float n_out18p0;
// Remap:18
	float n_in18p1 = 0.00000;
	float n_in18p2 = 1.00000;
	float n_in18p3 = -1.00000;
	float n_in18p4 = 1.00000;
	{
		float __input_range = n_in18p2 - n_in18p1;
		float __output_range = n_in18p4 - n_in18p3;
		n_out18p0 = n_in18p3 + __output_range * ((n_out10p0.x - n_in18p1) / __input_range);
	}


// FloatParameter:17
	float n_out17p0 = UVAmplitude;


// MultiplyAdd:14
	vec2 n_out14p0 = fma(vec2(n_out18p0), vec2(n_out17p0), n_out9p0);


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(Noise, n_out14p0);


	vec3 n_out19p0;
	vec3 n_out19p1;
// NoiseColorTransformer:19
	vec3 n_in19p1 = vec3(0.00000, 0.00000, 0.00000);
	float n_in19p3 = 0.25000;
	{
		n_out19p0
			 = noise_color_transformer(n_out22p0,vec3(n_out2p0.xyz));
			n_out19p1
			 = noise_normal_transformer(n_in19p1,vec3(n_out2p0.xyz),n_in19p3);
			
	}


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(Mask, n_out14p0);


// FloatConstant:8
	float n_out8p0 = 0.150000;


// Output:0
	ALBEDO = n_out19p0;
	ALPHA = n_out5p0.x;
	ALPHA_SCISSOR_THRESHOLD = n_out8p0;


}
"
